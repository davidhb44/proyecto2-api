const comentarios = [
  "Excelente estadía, el personal fue muy amable y las instalaciones estaban impecables.",
  "Buena ubicación pero el servicio de habitaciones tardó demasiado en llegar.",
  "La habitación era espaciosa y cómoda, definitivamente volvería a hospedarme aquí.",
  "El desayuno incluido fue delicioso, gran variedad de opciones para todos los gustos.",
  "Muy buen hotel en general, aunque el wifi tenía problemas de conexión intermitente.",
  "Las vistas desde la habitación eran increíbles, valió totalmente la pena el precio.",
  "Personal extremadamente atento y servicial durante toda la estadía, muy recomendado.",
  "La piscina no correspondía con lo que mostraban en las fotos del sitio web del hotel.",
  "Ubicación perfecta cerca de los principales atractivos turísticos de la ciudad.",
  "Ambiente tranquilo y acogedor, ideal para descansar después de un largo viaje.",
];

const respuestas = [
  "Gracias por su valoración, nos alegra que haya disfrutado su estadía con nosotros.",
  "Agradecemos su comentario, tomaremos en cuenta sus observaciones para mejorar.",
  "Lamentamos los inconvenientes, ya estamos trabajando para solucionarlo.",
  "Muchas gracias por elegir Dann-Alpes, esperamos verte de nuevo muy pronto.",
];

const hoteles = [1,1,1,2,2,2,3,3,3,4,4,5,5,6,6,7,7];

function rInt(a,b){ return Math.floor(Math.random()*(b-a+1))+a; }
function rElem(a){ return a[Math.floor(Math.random()*a.length)]; }
function rFecha(a,b){ return new Date(new Date(a).getTime()+Math.random()*(new Date(b)-new Date(a))); }

let docs = [];
let reserva_id = 1001;

for (let i = 0; i < hoteles.length; i++) {
  const hotel_id = hoteles[i];
  const cantidad = rInt(15, 20);
  for (let j = 0; j < cantidad; j++) {
    const fecha = rFecha("2024-01-01", "2024-12-31");
    const nVotos = rInt(0, 15);
    const votos = [];
    const votantes = new Set();
    while (votantes.size < Math.min(nVotos, 10)) votantes.add(rInt(1, 50));
    votantes.forEach(uid => votos.push({ usuario_id: NumberInt(uid), fecha: new Date(fecha.getTime() + rInt(1,5)*86400000) }));

    let doc = {
      hotel_id:     NumberInt(hotel_id),
      cliente_id:   NumberInt(rInt(1, 15)),
      reserva_id:   NumberInt(reserva_id++),
      calificacion: NumberInt(rInt(1, 5)),
      comentario:   rElem(comentarios),
      fecha:        fecha,
      estado:       "PUBLICADA",
      utilidad:     NumberInt(votos.length),
      destacada:    false,
      votos_utiles: votos
    };
    if (Math.random() < 0.60) {
      doc.respuesta_admin = {
        admin_id: NumberInt(rInt(1,3)),
        texto:    rElem(respuestas),
        fecha:    new Date(fecha.getTime() + 2*86400000)
      };
    }
    docs.push(doc);
  }
  if (hotel_id <= 3) {
    for (let k = 0; k < 8; k++) {
      docs.push({
        hotel_id:     NumberInt(hotel_id),
        cliente_id:   NumberInt(rInt(1,15)),
        reserva_id:   NumberInt(reserva_id++),
        calificacion: NumberInt(rInt(1,5)),
        comentario:   rElem(comentarios),
        fecha:        rFecha("2023-01-01","2023-12-31"),
        estado:       "PUBLICADA",
        utilidad:     NumberInt(0),
        destacada:    false,
        votos_utiles: []
      });
    }
  }
}

docs.push({
  hotel_id: NumberInt(1), cliente_id: NumberInt(1),
  reserva_id: NumberInt(9999), calificacion: NumberInt(1),
  comentario: "Esta reseña fue eliminada por violar las políticas de convivencia.",
  fecha: new Date("2024-03-10"), estado: "ELIMINADA",
  utilidad: NumberInt(0), destacada: false, votos_utiles: []
});

db.resenias.insertMany(docs);
print("Insertados: " + docs.length + " documentos");

[1,2,3,4,5,6,7].forEach(hid => {
  const r = db.resenias.findOne({ hotel_id: hid, estado: "PUBLICADA" });
  if (r) db.resenias.updateOne({ _id: r._id }, { $set: { destacada: true } });
});
print("Destacadas asignadas");
print("Total: " + db.resenias.countDocuments());
